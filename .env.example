# Deployment mode
INSTALL_MODE="domain"
CHUTES_COMPOSE_FILES="docker-compose.yml:docker-compose.domain.yml"
EDGE_SERVICE="caddy"
CHUTES_TRAFFIC_MODE="direct"
E2EE_PROXY_IMAGE="parachutes/e2ee-proxy:latest@sha256:0af4965c84e3eace05063fe2a013e818c30dd3687e9690a3bea83ae1df3b9a56"
CADDY_IMAGE="caddy:2.11.2-alpine@sha256:a1b7e624f860619cea121bdbc5dec2e112401666298c6507c6793b0a3ee6fc8e"
# Used only when CHUTES_TRAFFIC_MODE="e2ee-proxy"
ALLOW_NON_CONFIDENTIAL="false"
# Leave this disabled so n8n SSO text traffic stays on the proxy path too.
CHUTES_SSO_PROXY_BYPASS="false"
CHUTES_PROXY_BASE_URL=""
CHUTES_CREDENTIAL_TEST_BASE_URL=""

# Pinned app sources
N8N_VERSION="2.12.1"
N8N_SOURCE_REPO="https://github.com/n8n-io/n8n.git"
N8N_SOURCE_REF="n8n@2.12.1"
N8N_SOURCE_SHA="42c7f71b6863581044006af0309ac38aab8d7c9f"
OPENWEBUI_VERSION="v0.8.10"
OPENWEBUI_IMAGE="ghcr.io/open-webui/open-webui:v0.8.10@sha256:7eb132b5f14905ef4b07872428681151b6a98e024132cdc9e8124119780e2261"
# Advanced: reuse prebuilt local images instead of rebuilding app images during deploy.
# DROPZONE_N8N_IMAGE="chutes-dropzone-n8n:local"
# DROPZONE_OPENWEBUI_IMAGE="chutes-dropzone-openwebui:local"
# SKIP_APP_BUILDS="true"
TZ="UTC"

# Domain installs
DROPZONE_HOST="dropzone.example.com"
N8N_HOST="dropzone.example.com"
ACME_EMAIL="ops@example.com"

# Database (auto-generated by deploy.sh)
POSTGRES_USER="dropzone"
POSTGRES_PASSWORD=""
POSTGRES_N8N_DB="n8n"
POSTGRES_OPENWEBUI_DB="openwebui"
POSTGRES_DB="n8n"

# n8n secrets (auto-generated by deploy.sh)
# WARNING: N8N_ENCRYPTION_KEY encrypts stored credentials.
# Rotating it will strand all existing n8n credentials.
N8N_ENCRYPTION_KEY=""
N8N_JWT_SECRET=""
N8N_ADMIN_EMAIL="admin@chutes.local"
N8N_ADMIN_PASSWORD=""
N8N_EXPIRABLE_CREDENTIAL_REFRESH_WINDOW_SECONDS="300"

# OpenWebUI runtime (auto-generated by deploy.sh)
WEBUI_SECRET_KEY=""
OPENWEBUI_NAME="Chutes Chat"
OPENWEBUI_ADMIN_NAME="Chutes Chat Admin"
OPENWEBUI_ADMIN_EMAIL="admin@chutes.local"
OPENWEBUI_ADMIN_PASSWORD=""
OPENWEBUI_API_BASE_URL="https://llm.chutes.ai/v1"
OPENWEBUI_API_KEY=""
OPENWEBUI_MODELS_CACHE_TTL="300"
OPENWEBUI_MODEL_ORDER_SYNC_INTERVAL="300"

# Chutes SSO
CHUTES_OAUTH_CLIENT_ID=""
CHUTES_OAUTH_CLIENT_SECRET=""
CHUTES_IDP_BASE_URL="https://api.chutes.ai"
CHUTES_SSO_LOGIN_LABEL="Login with Chutes"
CHUTES_SSO_SCOPES="openid profile chutes:read chutes:invoke"
CHUTES_ADMIN_USERNAMES=""

# Optional deploy-time credential import for n8n
CHUTES_API_KEY=""
