#!/bin/sh
#
# s6 longrun: OpenWebUI
#
set -eu

DATA_DIR="${STANDALONE_OPENWEBUI_DATA_DIR:-/data/openwebui}"
APP_DATA_DIR="/app/backend/data"

mkdir -p "$DATA_DIR"

if [ -L "$APP_DATA_DIR" ]; then
    :
elif [ -d "$APP_DATA_DIR" ]; then
    if find "$APP_DATA_DIR" -mindepth 1 -maxdepth 1 >/dev/null 2>&1; then
        cp -a "$APP_DATA_DIR"/. "$DATA_DIR"/ 2>/dev/null || true
    fi
    rm -rf "$APP_DATA_DIR"
    ln -s "$DATA_DIR" "$APP_DATA_DIR"
else
    ln -s "$DATA_DIR" "$APP_DATA_DIR"
fi

cd /app/backend
echo "openwebui: starting"
exec ./start.sh
